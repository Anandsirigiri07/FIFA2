# 🏟️ StadiumIQ Pro — Environment Configuration Example
# Copy this file to .env and configure the values.

# 🚀 Express API Proxy Server Port (default: 3001)
PORT=3001

# 🧠 Google Gemini API Key for the Express Proxy Server
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# NOTE: Gemini API key is ONLY used server-side (see 
# GEMINI_API_KEY above). Never expose API keys with a 
# VITE_ prefix — those are bundled into the public 
# client JavaScript and can be stolen by anyone.

# 📡 Deployed Express Proxy Server URL (for production/deployed link client connectivity)
# Leave blank for default 'http://localhost:3001' local development connectivity.
VITE_PROXY_URL=
