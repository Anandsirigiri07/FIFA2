# 🏟️ StadiumIQ Pro — Environment Configuration Example
# Copy this file to .env and configure the values.

# 🚀 Express API Proxy Server Port (default: 3001)
PORT=3001

# 🧠 Google Gemini API Key for the Express Proxy Server
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 🌐 Google Gemini API Key for the Vite Client-Side Fallback (Production)
# Note: In Vite, variables prefixed with VITE_ are exposed to the client bundle.
# Make sure to keep the same key as above for direct client-side fallback connectivity.
VITE_GEMINI_API_KEY=your_gemini_api_key_here
